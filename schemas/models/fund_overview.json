{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FundOverview",
  "description": "基金概况（F10 / info 命令）。",
  "type": "object",
  "properties": {
    "allocation": {
      "anyOf": [
        {
          "$ref": "#/$defs/AssetAllocationSnapshot"
        },
        {
          "type": "null"
        }
      ]
    },
    "asset_size": {
      "type": "string"
    },
    "benchmark": {
      "type": "string"
    },
    "code": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "custody_fee": {
      "type": "number",
      "format": "double"
    },
    "establishment_date": {
      "type": "string"
    },
    "full_name": {
      "type": "string"
    },
    "fund_type": {
      "type": "string"
    },
    "investment_scope": {
      "type": "string"
    },
    "investment_target": {
      "type": "string"
    },
    "management_fee": {
      "type": "number",
      "format": "double"
    },
    "manager_name": {
      "type": "string"
    },
    "manager_tenure_days": {
      "type": "integer",
      "format": "int32"
    },
    "manager_total_return": {
      "type": "number",
      "format": "double"
    },
    "managers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/FundManagerView"
      }
    },
    "name": {
      "type": "string"
    },
    "peer_rank": {
      "$ref": "#/$defs/PeerRankInfo"
    }
  },
  "required": [
    "code",
    "name",
    "full_name",
    "fund_type",
    "establishment_date",
    "asset_size",
    "company",
    "manager_name",
    "manager_tenure_days",
    "manager_total_return",
    "management_fee",
    "custody_fee",
    "investment_target",
    "investment_scope",
    "benchmark"
  ],
  "$defs": {
    "AssetAllocationSnapshot": {
      "description": "最新资产配置快照（来自 F10 zcpz）。",
      "type": "object",
      "properties": {
        "as_of": {
          "type": "string"
        },
        "bond_pct": {
          "type": "number",
          "format": "double"
        },
        "cash_pct": {
          "type": "number",
          "format": "double"
        },
        "net_asset_yi": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "stock_pct": {
          "type": "number",
          "format": "double"
        },
        "stock_pct_chg": {
          "description": "相对上一期股票仓位变化（百分点）",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "as_of",
        "stock_pct",
        "bond_pct",
        "cash_pct"
      ]
    },
    "FundManagerView": {
      "description": "单个现任基金经理（呈现层）。",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "start_date": {
          "type": "string"
        },
        "tenure_days": {
          "type": "integer",
          "format": "int32"
        },
        "total_return": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "name",
        "tenure_days",
        "total_return"
      ]
    },
    "PeerRankInfo": {
      "description": "同类排名（近 3 月，来自天天基金 pingzhongdata）。",
      "type": "object",
      "properties": {
        "as_of": {
          "type": [
            "string",
            "null"
          ]
        },
        "peer_count": {
          "description": "同类基金数",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "percentile": {
          "description": "百分位 0–100（越高越好）",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "rank": {
          "description": "名次（1 最好）",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      }
    }
  }
}
