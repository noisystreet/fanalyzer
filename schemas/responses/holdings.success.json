{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HoldingsSuccessEnvelope",
  "type": "object",
  "properties": {
    "command": {
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/BatchPayload"
    },
    "meta": {
      "anyOf": [
        {
          "$ref": "#/$defs/BatchMeta"
        },
        {
          "type": "null"
        }
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "v": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "v",
    "command",
    "ok",
    "warnings",
    "data"
  ],
  "$defs": {
    "BatchMeta": {
      "description": "批量查询 meta。",
      "type": "object",
      "properties": {
        "duration_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "generated_at": {
          "type": "string"
        },
        "offline": {
          "type": "boolean"
        },
        "requested": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "succeeded": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "offline",
        "generated_at",
        "requested",
        "succeeded"
      ]
    },
    "BatchPayload": {
      "description": "多基金/多条目结果（含可选 partial errors）。",
      "type": "object",
      "properties": {
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ItemError"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HoldingsItem"
          }
        }
      },
      "required": [
        "items"
      ]
    },
    "HoldingsItem": {
      "description": "重仓股条目。",
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "holdings": {
          "$ref": "#/$defs/StockHoldings"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "name",
        "holdings"
      ]
    },
    "ItemError": {
      "description": "批量条目失败信息。",
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ]
    },
    "StockHoldingRow": {
      "description": "重仓股一行。",
      "type": "object",
      "properties": {
        "market_value_wan": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "pct_nav": {
          "type": "number",
          "format": "double"
        },
        "pct_nav_chg": {
          "description": "较上一报告期占净值变化（百分点）；未知时省略",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "rank": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "shares_wan": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "stock_code": {
          "type": "string"
        },
        "stock_name": {
          "type": "string"
        }
      },
      "required": [
        "rank",
        "stock_code",
        "stock_name",
        "pct_nav"
      ]
    },
    "StockHoldings": {
      "description": "重仓股报告。",
      "type": "object",
      "properties": {
        "as_of": {
          "type": [
            "string",
            "null"
          ]
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StockHoldingRow"
          }
        }
      },
      "required": [
        "rows"
      ]
    }
  }
}
