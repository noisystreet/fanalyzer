{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FetchSuccessEnvelope",
  "type": "object",
  "properties": {
    "command": {
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/BatchPayload"
    },
    "meta": {
      "anyOf": [
        {
          "$ref": "#/$defs/BatchMeta"
        },
        {
          "type": "null"
        }
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "v": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "v",
    "command",
    "ok",
    "warnings",
    "data"
  ],
  "$defs": {
    "BatchMeta": {
      "description": "批量查询 meta。",
      "type": "object",
      "properties": {
        "duration_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "generated_at": {
          "type": "string"
        },
        "offline": {
          "type": "boolean"
        },
        "requested": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "succeeded": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "offline",
        "generated_at",
        "requested",
        "succeeded"
      ]
    },
    "BatchPayload": {
      "description": "多基金/多条目结果（含可选 partial errors）。",
      "type": "object",
      "properties": {
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ItemError"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FetchPayload"
          }
        }
      },
      "required": [
        "items"
      ]
    },
    "FetchPayload": {
      "description": "净值拉取结果。",
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "fetched": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "name": {
          "type": "string"
        },
        "nav": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FundNav"
          }
        },
        "total": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "code",
        "name",
        "total",
        "fetched",
        "nav"
      ]
    },
    "FundNav": {
      "type": "object",
      "properties": {
        "acc_nav": {
          "type": "number",
          "format": "double"
        },
        "code": {
          "type": "string"
        },
        "daily_return": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "nav": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "code",
        "date",
        "nav",
        "acc_nav"
      ]
    },
    "ItemError": {
      "description": "批量条目失败信息。",
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ]
    }
  }
}
