{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SectorsSuccessEnvelope",
  "type": "object",
  "properties": {
    "command": {
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/BatchPayload"
    },
    "meta": {
      "anyOf": [
        {
          "$ref": "#/$defs/BatchMeta"
        },
        {
          "type": "null"
        }
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "v": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "v",
    "command",
    "ok",
    "warnings",
    "data"
  ],
  "$defs": {
    "BatchMeta": {
      "description": "批量查询 meta。",
      "type": "object",
      "properties": {
        "duration_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "generated_at": {
          "type": "string"
        },
        "offline": {
          "type": "boolean"
        },
        "requested": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "succeeded": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "offline",
        "generated_at",
        "requested",
        "succeeded"
      ]
    },
    "BatchPayload": {
      "description": "多基金/多条目结果（含可选 partial errors）。",
      "type": "object",
      "properties": {
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ItemError"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SectorItem"
          }
        }
      },
      "required": [
        "items"
      ]
    },
    "IndustryAllocation": {
      "description": "行业配置报告。",
      "type": "object",
      "properties": {
        "as_of": {
          "type": [
            "string",
            "null"
          ]
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IndustryRow"
          }
        }
      },
      "required": [
        "rows"
      ]
    },
    "IndustryRow": {
      "description": "行业配置一行。",
      "type": "object",
      "properties": {
        "industry": {
          "type": "string"
        },
        "market_value_wan": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "pct_nav": {
          "type": "number",
          "format": "double"
        },
        "rank": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "rank",
        "industry",
        "pct_nav"
      ]
    },
    "ItemError": {
      "description": "批量条目失败信息。",
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ]
    },
    "SectorItem": {
      "description": "行业配置条目。",
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "industry": {
          "$ref": "#/$defs/IndustryAllocation"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "name",
        "industry"
      ]
    }
  }
}
