{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalyzeSuccessEnvelope",
  "description": "json analyze 成功响应",
  "type": "object",
  "properties": {
    "command": {
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/BatchPayload"
    },
    "meta": {
      "anyOf": [
        {
          "$ref": "#/$defs/AnalysisMeta"
        },
        {
          "type": "null"
        }
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "v": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "v",
    "command",
    "ok",
    "warnings",
    "data"
  ],
  "$defs": {
    "AnalysisMeta": {
      "description": "分析类命令 meta。",
      "type": "object",
      "properties": {
        "days": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "duration_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "generated_at": {
          "type": "string"
        },
        "offline": {
          "type": "boolean"
        },
        "period": {
          "type": [
            "string",
            "null"
          ]
        },
        "requested": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "rolling_window": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "succeeded": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "offline",
        "generated_at",
        "days",
        "requested",
        "succeeded"
      ]
    },
    "BatchPayload": {
      "description": "多基金/多条目结果（含可选 partial errors）。",
      "type": "object",
      "properties": {
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ItemError"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FundAnalysisReport"
          }
        }
      },
      "required": [
        "items"
      ]
    },
    "FundAnalysis": {
      "type": "object",
      "properties": {
        "alpha": {
          "type": "number",
          "format": "double"
        },
        "annualized_return": {
          "type": "number",
          "format": "double"
        },
        "avg_nav": {
          "type": "number",
          "format": "double"
        },
        "beta": {
          "type": "number",
          "format": "double"
        },
        "calmar_ratio": {
          "type": "number",
          "format": "double"
        },
        "code": {
          "type": "string"
        },
        "custody_fee": {
          "type": "number",
          "format": "double"
        },
        "management_fee": {
          "type": "number",
          "format": "double"
        },
        "manager_name": {
          "type": "string"
        },
        "manager_tenure_days": {
          "type": "integer",
          "format": "int32"
        },
        "manager_total_return": {
          "type": "number",
          "format": "double"
        },
        "max_drawdown": {
          "type": "number",
          "format": "double"
        },
        "max_nav": {
          "type": "number",
          "format": "double"
        },
        "min_nav": {
          "type": "number",
          "format": "double"
        },
        "name": {
          "type": "string"
        },
        "period_days": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "sharpe_ratio": {
          "type": "number",
          "format": "double"
        },
        "sortino_ratio": {
          "type": "number",
          "format": "double"
        },
        "total_return": {
          "type": "number",
          "format": "double"
        },
        "volatility": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "code",
        "name",
        "period_days",
        "avg_nav",
        "max_nav",
        "min_nav",
        "total_return",
        "annualized_return",
        "volatility",
        "max_drawdown",
        "sharpe_ratio",
        "sortino_ratio",
        "calmar_ratio",
        "alpha",
        "beta",
        "manager_name",
        "manager_tenure_days",
        "manager_total_return",
        "management_fee",
        "custody_fee"
      ]
    },
    "FundAnalysisReport": {
      "description": "单基金完整分析报告（标量快照 + 可选时间序列）。",
      "type": "object",
      "properties": {
        "benchmark_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "series": {
          "anyOf": [
            {
              "$ref": "#/$defs/FundAnalysisSeries"
            },
            {
              "type": "null"
            }
          ]
        },
        "snapshot": {
          "$ref": "#/$defs/FundAnalysis"
        }
      },
      "required": [
        "snapshot"
      ]
    },
    "FundAnalysisSeries": {
      "description": "单基金滚动指标与净值/回撤曲线。",
      "type": "object",
      "properties": {
        "drawdown": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SeriesPoint"
          }
        },
        "nav_normalized": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SeriesPoint"
          }
        },
        "rolling_beta": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SeriesPoint"
          }
        },
        "rolling_sharpe": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SeriesPoint"
          }
        },
        "rolling_volatility": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SeriesPoint"
          }
        },
        "rolling_window": {
          "description": "滚动窗口（交易日）",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "rolling_window",
        "nav_normalized",
        "drawdown",
        "rolling_sharpe",
        "rolling_beta",
        "rolling_volatility"
      ]
    },
    "ItemError": {
      "description": "批量条目失败信息。",
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ]
    },
    "SeriesPoint": {
      "description": "单个时间序列数据点。",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "value": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "date",
        "value"
      ]
    }
  }
}
