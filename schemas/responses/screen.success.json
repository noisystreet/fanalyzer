{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScreenSuccessEnvelope",
  "type": "object",
  "properties": {
    "command": {
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/ScreenPayload"
    },
    "meta": {
      "anyOf": [
        {
          "$ref": "#/$defs/ScreenMeta"
        },
        {
          "type": "null"
        }
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "v": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "v",
    "command",
    "ok",
    "warnings",
    "data"
  ],
  "$defs": {
    "FundAnalysis": {
      "type": "object",
      "properties": {
        "alpha": {
          "type": "number",
          "format": "double"
        },
        "annualized_return": {
          "type": "number",
          "format": "double"
        },
        "avg_nav": {
          "type": "number",
          "format": "double"
        },
        "beta": {
          "type": "number",
          "format": "double"
        },
        "calmar_ratio": {
          "type": "number",
          "format": "double"
        },
        "code": {
          "type": "string"
        },
        "custody_fee": {
          "type": "number",
          "format": "double"
        },
        "management_fee": {
          "type": "number",
          "format": "double"
        },
        "manager_name": {
          "type": "string"
        },
        "manager_tenure_days": {
          "type": "integer",
          "format": "int32"
        },
        "manager_total_return": {
          "type": "number",
          "format": "double"
        },
        "max_drawdown": {
          "type": "number",
          "format": "double"
        },
        "max_nav": {
          "type": "number",
          "format": "double"
        },
        "min_nav": {
          "type": "number",
          "format": "double"
        },
        "name": {
          "type": "string"
        },
        "period_days": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "sharpe_ratio": {
          "type": "number",
          "format": "double"
        },
        "sortino_ratio": {
          "type": "number",
          "format": "double"
        },
        "total_return": {
          "type": "number",
          "format": "double"
        },
        "volatility": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "code",
        "name",
        "period_days",
        "avg_nav",
        "max_nav",
        "min_nav",
        "total_return",
        "annualized_return",
        "volatility",
        "max_drawdown",
        "sharpe_ratio",
        "sortino_ratio",
        "calmar_ratio",
        "alpha",
        "beta",
        "manager_name",
        "manager_tenure_days",
        "manager_total_return",
        "management_fee",
        "custody_fee"
      ]
    },
    "ScreenMeta": {
      "description": "筛选 meta。",
      "type": "object",
      "properties": {
        "analyzed": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "days": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "duration_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "generated_at": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "offline": {
          "type": "boolean"
        },
        "pool_size": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "sort": {
          "type": "string"
        }
      },
      "required": [
        "offline",
        "generated_at",
        "kind",
        "sort",
        "days",
        "pool_size",
        "analyzed"
      ]
    },
    "ScreenPayload": {
      "description": "筛选结果。",
      "type": "object",
      "properties": {
        "analyzed": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "days": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "kind": {
          "type": "string"
        },
        "passed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FundAnalysis"
          }
        },
        "pool_size": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "sort": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "sort",
        "days",
        "pool_size",
        "analyzed",
        "passed"
      ]
    }
  }
}
